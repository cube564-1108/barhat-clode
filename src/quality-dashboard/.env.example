# Pyrus API credentials
PYRUS_API_TOKEN=your_pyrus_api_token_here

# Flask settings
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change_this_in_production

# Security (secret header for basic protection)
SECRET_HEADER_NAME=X-Secret-Header
SECRET_HEADER_VALUE=your_secret_value_here

# Dashboard settings
PYRUS_FORM_ID=1327961
CACHE_TIMEOUT_SECONDS=300
